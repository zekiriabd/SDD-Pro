{
  "$schema": "../../templates/libs-catalog.schema.json",
  "stackId": "react-native",
  "category": "mobiles",
  "schemaVersion": 1,
  "buildSystem": "npm",
  "manifest": {
    "files": [
      "workspace/output/src/{AppName}/package.json",
      "workspace/output/src/{AppName}/app.json",
      "workspace/output/src/{AppName}/tsconfig.json",
      "workspace/output/src/{AppName}/babel.config.js",
      "workspace/output/src/{AppName}/metro.config.js",
      "workspace/output/src/{AppName}/tailwind.config.js"
    ]
  },
  "metadata": {
    "platforms": ["ios", "android"],
    "workflow": "expo-managed",
    "newArchitecture": true,
    "notes": "Mobile stack consomme un backend separe declare dans ## Active Tech Specs. category=mobiles (depuis schema v1 etendu 2026-05-16)."
  },
  "versions": {
    "expo": "52.0.20",
    "react": "19.0.0",
    "react-native": "0.76.5",
    "react-dom": "19.0.0",
    "typescript": "5.7.2",
    "react-types": "19.0.2",
    "expo-router": "4.0.15",
    "expo-status-bar": "2.0.0",
    "expo-constants": "17.0.3",
    "expo-linking": "7.0.3",
    "expo-splash-screen": "0.29.18",
    "expo-font": "13.0.1",
    "expo-image": "2.0.3",
    "expo-localization": "16.0.0",
    "expo-secure-store": "14.0.1",
    "react-native-screens": "4.4.0",
    "react-native-safe-area-context": "5.0.0",
    "react-native-gesture-handler": "2.21.2",
    "react-native-reanimated": "3.16.7",
    "nativewind": "4.1.23",
    "tailwindcss": "3.4.17",
    "zustand": "5.0.2",
    "tanstack-query": "5.62.7",
    "react-hook-form": "7.54.2",
    "hookform-resolvers": "3.10.0",
    "zod": "3.24.1",
    "async-storage": "2.1.0",
    "eslint": "9.17.0",
    "eslint-config-expo": "8.0.1",
    "axios": "1.7.9",
    "date-fns": "4.1.0",
    "dayjs": "1.11.13",
    "lucide-rn": "0.469.0",
    "expo-vector-icons": "14.0.4",
    "keyboard-controller": "1.16.0",
    "flash-list": "1.7.3",
    "mmkv": "3.1.0",
    "expo-sqlite": "15.0.4",
    "expo-camera": "16.0.7",
    "vision-camera": "4.6.1",
    "expo-barcode-scanner": "13.0.1",
    "expo-image-picker": "16.0.4",
    "expo-location": "18.0.4",
    "react-native-maps": "1.20.1",
    "mapbox-maps": "10.1.34",
    "expo-notifications": "0.29.11",
    "msal-react-native": "1.0.0",
    "expo-auth-session": "6.0.2",
    "expo-local-auth": "15.0.2",
    "sentry-rn": "6.4.0",
    "i18next": "24.1.2",
    "react-i18next": "15.4.0",
    "stripe-rn": "0.41.0",
    "webview": "13.13.1",
    "rn-svg": "15.10.2",
    "jotai": "2.11.0"
  },
  "core": [
    { "module": "expo", "ref": "expo", "rationale": "SDK Expo (Metro, modules natifs, EAS Build)" },
    { "module": "react", "ref": "react" },
    { "module": "react-native", "ref": "react-native" },
    { "module": "react-dom", "ref": "react-dom", "rationale": "Necessaire pour Expo Web optionnel" },
    { "module": "typescript", "ref": "typescript" },
    { "module": "@types/react", "ref": "react-types" },
    { "module": "expo-router", "ref": "expo-router", "rationale": "File-based routing — defaut Expo SDK 51+" },
    { "module": "expo-status-bar", "ref": "expo-status-bar" },
    { "module": "expo-constants", "ref": "expo-constants" },
    { "module": "expo-linking", "ref": "expo-linking", "rationale": "Deep linking + Universal Links" },
    { "module": "expo-splash-screen", "ref": "expo-splash-screen" },
    { "module": "expo-font", "ref": "expo-font" },
    { "module": "expo-image", "ref": "expo-image", "rationale": "Cache + transformations (remplace RN Image)" },
    { "module": "expo-localization", "ref": "expo-localization" },
    { "module": "expo-secure-store", "ref": "expo-secure-store", "rationale": "Tokens JWT, secrets (Keychain iOS / Keystore Android)" },
    { "module": "react-native-screens", "ref": "react-native-screens", "rationale": "Peer Expo Router (native screens)" },
    { "module": "react-native-safe-area-context", "ref": "react-native-safe-area-context", "rationale": "Peer Expo Router (notch / status bar insets)" },
    { "module": "react-native-gesture-handler", "ref": "react-native-gesture-handler", "rationale": "Peer Expo Router (gestures natifs)" },
    { "module": "react-native-reanimated", "ref": "react-native-reanimated", "rationale": "Animations natives 60fps, peer plusieurs libs" },
    { "module": "nativewind", "ref": "nativewind", "rationale": "Tailwind compile vers StyleSheet RN — top-1 styling 2024-2025" },
    { "module": "tailwindcss", "ref": "tailwindcss", "rationale": "Peer NativeWind — v3 obligatoire (v4 incompat RN)" },
    { "module": "zustand", "ref": "zustand", "rationale": "State manager client — top-1 simple, succede Redux/Context" },
    { "module": "@tanstack/react-query", "ref": "tanstack-query", "rationale": "Server state cache — standard de facto" },
    { "module": "react-hook-form", "ref": "react-hook-form", "rationale": "Forms — meme stack que web/react.md" },
    { "module": "@hookform/resolvers", "ref": "hookform-resolvers" },
    { "module": "zod", "ref": "zod", "rationale": "Validation forms + parsing API responses" },
    { "module": "@react-native-async-storage/async-storage", "ref": "async-storage", "rationale": "KV storage non sensible — standard RN" },
    { "module": "eslint", "ref": "eslint" },
    { "module": "eslint-config-expo", "ref": "eslint-config-expo" }
  ],
  "onDemand": [
    { "module": "axios", "ref": "axios", "capability": "http-client", "triggers": ["\\baxios\\b", "http-client", "appel.*api.*externe"] },
    { "module": "date-fns", "ref": "date-fns", "capability": "date-utils", "triggers": ["dates.*format", "duree", "intervalle.*temps"] },
    { "module": "dayjs", "ref": "dayjs", "capability": "date-utils", "triggers": ["dayjs", "dates.*format"], "alternative": true },
    { "module": "lucide-react-native", "ref": "lucide-rn", "capability": "icons", "triggers": ["icones", "icon-set", "lucide"] },
    { "module": "@expo/vector-icons", "ref": "expo-vector-icons", "capability": "icons", "triggers": ["icones", "vector-icons", "ionicons", "material-icons"], "alternative": true },
    { "module": "react-native-keyboard-controller", "ref": "keyboard-controller", "capability": "forms-ui", "triggers": ["keyboard.*controller", "forms.*native"] },
    { "module": "@shopify/flash-list", "ref": "flash-list", "capability": "flashlist", "triggers": ["grandes.*listes", "performance.*list", "virtualization"] },
    { "module": "react-native-mmkv", "ref": "mmkv", "capability": "mmkv", "triggers": ["mmkv", "kv.*rapide", "performance.*storage"] },
    { "module": "expo-sqlite", "ref": "expo-sqlite", "capability": "offline-db", "triggers": ["sqlite", "offline-first", "local.*db", "persistance.*locale"] },
    { "module": "expo-camera", "ref": "expo-camera", "capability": "camera", "triggers": ["camera", "scan.*qr", "photo"] },
    { "module": "react-native-vision-camera", "ref": "vision-camera", "capability": "camera", "triggers": ["vision-camera", "photo.*haute.*qualite", "video"], "alternative": true },
    { "module": "expo-barcode-scanner", "ref": "expo-barcode-scanner", "capability": "barcode", "triggers": ["scan.*barcode", "scan.*qr", "code-barre"] },
    { "module": "expo-image-picker", "ref": "expo-image-picker", "capability": "image-picker", "triggers": ["gallerie", "image-picker", "choisir.*photo"] },
    { "module": "expo-location", "ref": "expo-location", "capability": "location", "triggers": ["gps", "location", "geolocalisation"] },
    { "module": "react-native-maps", "ref": "react-native-maps", "capability": "maps", "triggers": ["maps", "carte", "marker", "google.*maps"] },
    { "module": "@rnmapbox/maps", "ref": "mapbox-maps", "capability": "maps", "triggers": ["mapbox", "carte.*custom"], "alternative": true },
    { "module": "expo-notifications", "ref": "expo-notifications", "capability": "push", "triggers": ["push.*notification", "notification.*push"] },
    { "module": "@azure/msal-react-native", "ref": "msal-react-native", "capability": "auth-azure-ad", "triggers": ["azure-ad", "msal", "sso"] },
    { "module": "expo-auth-session", "ref": "expo-auth-session", "capability": "auth-local", "triggers": ["oauth", "auth-local", "oidc"] },
    { "module": "expo-local-authentication", "ref": "expo-local-auth", "capability": "biometric", "triggers": ["biometric", "face-id", "touch-id", "fingerprint"] },
    { "module": "@sentry/react-native", "ref": "sentry-rn", "capability": "sentry", "triggers": ["sentry", "error.*tracking", "monitoring.*erreurs"] },
    { "module": "i18next", "ref": "i18next", "capability": "i18n", "triggers": ["i18n", "multi.*langue", "traductions"] },
    { "module": "react-i18next", "ref": "react-i18next", "capability": "i18n", "triggers": ["i18n", "react-i18next"] },
    { "module": "@stripe/stripe-react-native", "ref": "stripe-rn", "capability": "stripe", "triggers": ["stripe", "paiement", "payment"] },
    { "module": "react-native-webview", "ref": "webview", "capability": "webview", "triggers": ["webview", "embed.*page.*web"] },
    { "module": "react-native-svg", "ref": "rn-svg", "capability": "svg", "triggers": ["svg", "vector.*graphics"] },
    { "module": "jotai", "ref": "jotai", "capability": "reactive-state", "triggers": ["jotai", "atomic.*state"], "alternative": true }
  ]
}
