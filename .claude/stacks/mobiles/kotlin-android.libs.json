{
  "$schema": "../../templates/libs-catalog.schema.json",
  "stackId": "kotlin-android",
  "category": "mobiles",
  "schemaVersion": 1,
  "buildSystem": "gradle",
  "manifest": {
    "files": [
      "workspace/output/src/{AppName}/build.gradle.kts",
      "workspace/output/src/{AppName}/gradle/libs.versions.toml",
      "workspace/output/src/{AppName}/settings.gradle.kts"
    ],
    "versionCatalogPath": "gradle/libs.versions.toml"
  },
  "versions": {
    "kotlin": "2.0.21",
    "agp": "8.6.1",
    "compile-sdk": "36",
    "min-sdk": "24",
    "target-sdk": "36",
    "compose": "1.7.0",
    "compose-material3": "1.3.1",
    "androidx-core": "1.15.0",
    "androidx-activity": "1.9.0",
    "androidx-lifecycle": "2.8.0",
    "androidx-room": "2.6.1",
    "androidx-datastore": "1.1.1",
    "androidx-work": "2.10.0",
    "hilt": "2.51",
    "ksp": "2.0.21-1.0.27",
    "retrofit": "2.11.0",
    "okhttp": "4.12.0",
    "kotlinx-json": "1.7.0",
    "timber": "5.0.1",
    "junit": "4.13.2",
    "mockito": "5.7.0",
    "espresso": "3.5.1",
    "accompanist": "0.36.0",
    "firebase": "33.7.0",
    "camera": "1.4.0",
    "google-maps": "6.2.1",
    "paging": "3.3.4",
    "spotless": "7.0.0"
  },
  "core": [
    {
      "module": "org.jetbrains.kotlin:kotlin-stdlib",
      "ref": "kotlin",
      "rationale": "Stdlib Kotlin core"
    },
    {
      "module": "com.android.tools.build:gradle",
      "ref": "agp",
      "rationale": "Android Gradle Plugin (compilateur, packaging APK/AAB, resource merging)"
    },
    {
      "module": "androidx.compose.ui:ui",
      "ref": "compose",
      "rationale": "Jetpack Compose UI foundation (Layout, Modifier, State)"
    },
    {
      "module": "androidx.compose.material3:material3",
      "ref": "compose-material3",
      "rationale": "Material Design 3 components (Button, Card, TextField, Navigation, etc.)"
    },
    {
      "module": "androidx.compose.runtime:runtime",
      "ref": "compose",
      "rationale": "Compose runtime (Recomposition, State, Effect)"
    },
    {
      "module": "androidx.compose.foundation:foundation",
      "ref": "compose",
      "rationale": "Foundation layouts (Box, Row, Column, LazyColumn, LazyRow, ScrollState)"
    },
    {
      "module": "androidx.navigation:navigation-compose",
      "ref": "compose",
      "rationale": "Navigation Compose (NavController, NavGraph, Routes typées)"
    },
    {
      "module": "androidx.core:core-ktx",
      "ref": "androidx-core",
      "rationale": "Android core APIs extensions (Context, SharedPreferences, etc.)"
    },
    {
      "module": "androidx.activity:activity-compose",
      "ref": "androidx-activity",
      "rationale": "Activity integration with Compose (setContent, LocalContext)"
    },
    {
      "module": "androidx.lifecycle:lifecycle-runtime-ktx",
      "ref": "androidx-lifecycle",
      "rationale": "Lifecycle-aware coroutines (lifecycleScope, repeatOnLifecycle)"
    },
    {
      "module": "androidx.lifecycle:lifecycle-viewmodel-ktx",
      "ref": "androidx-lifecycle",
      "rationale": "ViewModel lifecycle management (viewModelScope)"
    },
    {
      "module": "androidx.lifecycle:lifecycle-viewmodel-compose",
      "ref": "androidx-lifecycle",
      "rationale": "ViewModel integration with Compose (hiltViewModel, collectAsStateWithLifecycle)"
    },
    {
      "module": "androidx.room:room-runtime",
      "ref": "androidx-room",
      "rationale": "Room persistence library (SQLite ORM avec @Entity, @Dao, @Database)"
    },
    {
      "module": "androidx.room:room-ktx",
      "ref": "androidx-room",
      "rationale": "Room Kotlin extensions (suspend functions, Flow queries)"
    },
    {
      "module": "androidx.datastore:datastore-preferences",
      "ref": "androidx-datastore",
      "rationale": "DataStore async key-value storage (preference moderne, replacement SharedPreferences)"
    },
    {
      "module": "com.google.dagger:hilt-android",
      "ref": "hilt",
      "rationale": "Hilt dependency injection (DI scopes, @Inject, @Module, @HiltViewModel)"
    },
    {
      "module": "com.squareup.retrofit2:retrofit",
      "ref": "retrofit",
      "rationale": "Retrofit HTTP client (REST API, declarative, interceptors, suspend fun)"
    },
    {
      "module": "com.squareup.retrofit2:converter-kotlinx-serialization",
      "ref": "retrofit",
      "rationale": "Retrofit converter Kotlin Serialization (JSON deserialization)"
    },
    {
      "module": "com.squareup.okhttp3:okhttp",
      "ref": "okhttp",
      "rationale": "OkHttp HTTP client core (connection pooling, interceptors, request/response logging)"
    },
    {
      "module": "com.squareup.okhttp3:logging-interceptor",
      "ref": "okhttp",
      "rationale": "OkHttp logging interceptor (debug HTTP requests/responses)"
    },
    {
      "module": "org.jetbrains.kotlinx:kotlinx-serialization-json",
      "ref": "kotlinx-json",
      "rationale": "Kotlin Serialization JSON parser (alternative Jackson/GSON, Kotlin-native)"
    },
    {
      "module": "com.jakewharton.timber:timber",
      "ref": "timber",
      "rationale": "Timber logging library (wrapper SLF4J-like Android, debug tree plugin)"
    },
    {
      "module": "org.jetbrains.kotlinx:kotlinx-coroutines-android",
      "ref": "kotlin",
      "rationale": "Kotlin Coroutines Android support (Dispatchers.Main)"
    },
    {
      "module": "org.jetbrains.kotlinx:kotlinx-coroutines-core",
      "ref": "kotlin",
      "rationale": "Kotlin Coroutines core (Flow, async, launch, withContext)"
    }
  ],
  "onDemand": [
    {
      "module": "com.google.firebase:firebase-bom",
      "ref": "firebase",
      "capability": "firebase",
      "rationale": "Firebase Bill of Materials (versioning transitive dependencies: messaging, auth, firestore, analytics)",
      "triggers": ["\\bfirebase\\b", "cloud messaging", "notifications push", "fcm"]
    },
    {
      "module": "com.google.firebase:firebase-messaging-ktx",
      "ref": "firebase",
      "capability": "firebase",
      "triggers": ["\\bfirebase\\b", "cloud messaging", "notifications push"]
    },
    {
      "module": "androidx.room:room-ktx",
      "ref": "androidx-room",
      "capability": "room-database",
      "rationale": "Room persistence already in core for basic cases; this extends for advanced scenarios (migrations, testing)",
      "triggers": ["\\broom\\b", "database local", "sqlite persistence", "dao"]
    },
    {
      "module": "androidx.camera:camera-core",
      "ref": "camera",
      "capability": "camera",
      "rationale": "AndroidX Camera library (camera preview, capture photos/videos, lifecycle-aware)",
      "triggers": ["\\bcamera\\b", "photo capture", "video record", "image picker"]
    },
    {
      "module": "androidx.camera:camera-camera2",
      "ref": "camera",
      "capability": "camera",
      "triggers": ["\\bcamera\\b", "photo capture", "video record"]
    },
    {
      "module": "androidx.camera:camera-lifecycle",
      "ref": "camera",
      "capability": "camera",
      "triggers": ["\\bcamera\\b"]
    },
    {
      "module": "com.google.accompanist:accompanist-permissions",
      "ref": "accompanist",
      "capability": "permissions",
      "rationale": "Accompanist permissions (runtime permissions Compose, @Composable permission UI)",
      "triggers": ["permissions runtime", "permission compose", "permission ui"]
    },
    {
      "module": "androidx.work:work-runtime-ktx",
      "ref": "androidx-work",
      "capability": "background-jobs",
      "rationale": "WorkManager background job scheduling (periodic tasks, constraints, battery optimization)",
      "triggers": ["background job", "scheduled task", "periodic work", "workmanager"]
    },
    {
      "module": "com.google.maps.android:maps-compose",
      "ref": "google-maps",
      "capability": "google-maps",
      "rationale": "Google Maps Compose (Google Maps SDK intégration via Compose)",
      "triggers": ["google maps", "\\bmaps\\b", "location map"]
    },
    {
      "module": "androidx.paging:paging-compose",
      "ref": "paging",
      "capability": "paging",
      "rationale": "Jetpack Paging 3 Compose integration (LazyPagingItems, infinite scroll)",
      "triggers": ["paging", "pagination", "lazy load", "infinite scroll"]
    }
  ],
  "plugins": [
    {
      "id": "com.android.application",
      "ref": "agp",
      "rationale": "Android Application plugin (cible apk/aab, resource packaging, manifest merging)"
    },
    {
      "id": "kotlin-android",
      "ref": "kotlin",
      "rationale": "Kotlin Android plugin (compilateur Kotlin/JVM, Kotlin sources integration)"
    },
    {
      "id": "com.google.dagger.hilt.android",
      "ref": "hilt",
      "rationale": "Hilt plugin (code generation DI, @HiltAndroidApp, @HiltViewModel)"
    },
    {
      "id": "com.google.devtools.ksp",
      "ref": "ksp",
      "rationale": "Kotlin Symbol Processing (KSP compiler plugin pour annotation processors: Hilt, Room, etc.)"
    },
    {
      "id": "com.diffplug.spotless",
      "ref": "spotless",
      "rationale": "Spotless formatter (ktfmt Kotlin formatting, tasks spotlessCheck / spotlessApply)"
    }
  ],
  "metadata": {
    "lastUpdated": "2026-05-24",
    "format": "compact (v2)",
    "maintainer": "SDD_Pro Framework",
    "notes": "Kotlin Android native stack cible API 24-36 (Android 7.0-14). Jetpack Compose declarative UI, Hilt DI, Retrofit+OkHttp, Room+Datastore, Coroutines+Flow. Clean Architecture (Domain-Data-Presentation). Mono-projet {AppName}/ sous workspace/output/src/."
  }
}
