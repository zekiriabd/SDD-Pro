{
  "$schema": "../../templates/libs-catalog.schema.json",
  "stackId": "node-express",
  "category": "backend",
  "schemaVersion": 1,
  "buildSystem": "pnpm",
  "manifest": {
    "files": [
      "workspace/output/src/{BackendName}/package.json",
      "workspace/output/src/{BackendName}/tsconfig.json"
    ]
  },
  "versions": {
    "express": "4.21.2",
    "prisma": "6.1.0",
    "pino": "9.5.0",
    "pino-http": "10.3.0",
    "pino-pretty": "13.0.0",
    "zod": "3.24.0",
    "swagger-jsdoc": "6.2.8",
    "swagger-ui-express": "5.0.1",
    "helmet": "8.0.0",
    "cors": "2.8.5",
    "dotenv": "16.4.7",
    "uuid": "11.0.5",
    "dayjs": "1.11.13",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "bcrypt": "5.1.1",
    "jsonwebtoken": "9.0.2",
    "axios": "1.7.9",
    "axios-retry": "4.5.0",
    "exceljs": "4.4.0",
    "pdfkit": "0.15.2",
    "multer": "2.0.0",
    "compression": "1.7.5",
    "express-rate-limit": "7.4.1",
    "typescript": "5.6.3",
    "ts-node-dev": "2.0.0",
    "tsc-alias": "1.8.10",
    "node-types": "22.10.0",
    "express-types": "5.0.0",
    "cors-types": "2.8.17",
    "uuid-types": "10.0.0",
    "swagger-jsdoc-types": "6.0.4",
    "swagger-ui-types": "4.1.7",
    "bcrypt-types": "5.0.2",
    "jsonwebtoken-types": "9.0.7",
    "multer-types": "1.4.12",
    "eslint": "9.17.0",
    "typescript-eslint": "8.18.1"
  },
  "core": [
    { "module": "express", "ref": "express" },
    { "module": "prisma", "ref": "prisma" },
    { "module": "@prisma/client", "ref": "prisma" },
    { "module": "pino", "ref": "pino" },
    { "module": "pino-http", "ref": "pino-http" },
    { "module": "pino-pretty", "ref": "pino-pretty" },
    { "module": "zod", "ref": "zod" },
    { "module": "swagger-jsdoc", "ref": "swagger-jsdoc" },
    { "module": "swagger-ui-express", "ref": "swagger-ui-express" },
    { "module": "helmet", "ref": "helmet" },
    { "module": "cors", "ref": "cors" },
    { "module": "dotenv", "ref": "dotenv" },
    { "module": "compression", "ref": "compression" },
    { "module": "express-rate-limit", "ref": "express-rate-limit" },
    { "module": "typescript", "ref": "typescript" },
    { "module": "ts-node-dev", "ref": "ts-node-dev" },
    { "module": "tsc-alias", "ref": "tsc-alias" },
    { "module": "@types/node", "ref": "node-types" },
    { "module": "@types/express", "ref": "express-types" },
    { "module": "@types/cors", "ref": "cors-types" },
    { "module": "@types/swagger-jsdoc", "ref": "swagger-jsdoc-types" },
    { "module": "@types/swagger-ui-express", "ref": "swagger-ui-types" },
    { "module": "eslint", "ref": "eslint" },
    { "module": "typescript-eslint", "ref": "typescript-eslint" }
  ],
  "onDemand": [
    { "module": "uuid", "ref": "uuid", "capability": "uuid-gen", "triggers": ["\\buuid\\b", "guid.*genere", "id.*aleatoire"] },
    { "module": "@types/uuid", "ref": "uuid-types", "capability": "uuid-gen", "triggers": ["\\buuid\\b", "guid.*genere", "id.*aleatoire"] },
    { "module": "dayjs", "ref": "dayjs", "capability": "date-utils", "triggers": ["dates.*format", "duree", "intervalle.*temps"] },
    { "module": "bcrypt", "ref": "bcrypt", "capability": "auth-local", "triggers": ["auth-local", "hash.*password", "bcrypt"], "rationale": "Native bcrypt (kelektiv/node.bcrypt.js) — bcryptjs deprecated upstream 2025, ~10x plus rapide donc cost factor sain" },
    { "module": "@types/bcrypt", "ref": "bcrypt-types", "capability": "auth-local", "triggers": ["auth-local", "hash.*password", "bcrypt"] },
    { "module": "jsonwebtoken", "ref": "jsonwebtoken", "capability": "jwt", "triggers": ["\\bjwt\\b", "auth-local", "auth-azure-ad"] },
    { "module": "@types/jsonwebtoken", "ref": "jsonwebtoken-types", "capability": "jwt", "triggers": ["\\bjwt\\b", "auth-local", "auth-azure-ad"] },
    { "module": "axios", "ref": "axios", "capability": "http-client", "triggers": ["\\baxios\\b", "appel.*api.*externe", "service.*externe", "third.party"] },
    { "module": "axios-retry", "ref": "axios-retry", "capability": "http-client", "triggers": ["\\baxios\\b", "retry.*http", "resilience"] },
    { "module": "exceljs", "ref": "exceljs", "capability": "excel", "triggers": ["\\bexcel\\b", "\\.xlsx\\b", "export.*excel", "import.*excel", "tableur"] },
    { "module": "pdfkit", "ref": "pdfkit", "capability": "pdf", "triggers": ["\\bpdf\\b", "\\.pdf\\b", "export.*pdf", "generer.*pdf"] },
    { "module": "multer", "ref": "multer", "capability": "file-upload", "triggers": ["upload.*fichier", "multipart", "form-data"] },
    { "module": "@types/multer", "ref": "multer-types", "capability": "file-upload", "triggers": ["upload.*fichier", "multipart", "form-data"] },
    { "module": "class-transformer", "ref": "class-transformer", "capability": "object-mapping", "triggers": ["class-transformer", "auto.*mapping", "dto.*mapping"] },
    { "module": "class-validator", "ref": "class-validator", "capability": "decorator-validation", "triggers": ["class-validator", "decorator.*validation"], "alternative": true }
  ],
  "plugins": [],
  "metadata": { "lastUpdated": "2026-05-07", "format": "compact (v2)" }
}
