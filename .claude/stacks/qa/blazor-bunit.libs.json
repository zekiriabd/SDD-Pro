{
  "$schema": "../../templates/libs-catalog.schema.json",
  "stackId": "blazor-bunit",
  "category": "qa",
  "schemaVersion": 1,
  "buildSystem": "dotnet",
  "manifest": {
    "files": ["workspace/output/src/{AppName}.Tests/{AppName}.Tests.csproj"]
  },
  "versions": {
    "bunit": "1.36.0",
    "xunit": "2.9.2",
    "xunit-runner": "3.0.0",
    "dotnet-test-sdk": "17.12.0",
    "coverlet": "6.0.2",
    "nsubstitute": "5.3.0",
    "moq": "4.20.72",
    "fluentassertions": "7.0.0"
  },
  "core": [
    { "module": "bunit.web", "ref": "bunit" },
    { "module": "xunit", "ref": "xunit" },
    { "module": "xunit.runner.visualstudio", "ref": "xunit-runner" },
    { "module": "Microsoft.NET.Test.Sdk", "ref": "dotnet-test-sdk" },
    { "module": "coverlet.collector", "ref": "coverlet" },
    { "module": "NSubstitute", "ref": "nsubstitute" }
  ],
  "onDemand": [
    { "module": "Moq", "ref": "moq", "capability": "mocking-alt", "triggers": ["\\bmoq\\b"], "alternative": true },
    { "module": "FluentAssertions", "ref": "fluentassertions", "capability": "fluent-assertions", "triggers": ["fluentassertions", "should\\(\\)"] }
  ],
  "plugins": [],
  "metadata": { "lastUpdated": "2026-05-07", "format": "compact (v2)" }
}
