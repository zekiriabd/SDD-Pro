{
  "$schema": "../../templates/libs-catalog.schema.json",
  "stackId": "next",
  "category": "fullstack",
  "schemaVersion": 1,
  "buildSystem": "npm",
  "manifest": {
    "files": [
      "workspace/output/src/{AppName}/package.json",
      "workspace/output/src/{AppName}/next.config.mjs",
      "workspace/output/src/{AppName}/tsconfig.json",
      "workspace/output/src/{AppName}/components.json"
    ]
  },
  "metadata": {
    "platforms": ["node-22"],
    "framework": "Next.js 15 App Router + RSC + Server Actions",
    "workflow": "single-project-ssr-rsc",
    "notes": "Build step obligatoire (next build). Turbopack/Webpack 5 integre. shadcn/ui via composants react.libs.json equivalent."
  },
  "versions": {
    "next": "15.1.0",
    "react": "19.0.0",
    "react-types": "19.0.2",
    "react-dom-types": "19.0.2",
    "typescript": "5.7.0",
    "node-types": "22.10.0",
    "tailwindcss": "4.0.0",
    "postcss": "8.5.0",
    "zod": "3.24.0",
    "react-hook-form": "7.54.2",
    "hookform-resolvers": "3.10.0",
    "next-auth": "5.0.0-beta.25",
    "next-intl": "3.26.0",
    "pino": "9.5.0",
    "pino-pretty": "13.0.0",
    "eslint": "9.17.0",
    "eslint-next": "15.1.0",
    "prisma": "6.1.0",
    "prisma-client": "6.1.0",
    "msal-node": "3.1.0",
    "jose": "5.9.6",
    "undici": "7.2.0",
    "exceljs": "4.4.0",
    "react-pdf": "4.1.5",
    "nodemailer": "6.9.16",
    "date-fns": "4.1.0",
    "zustand": "5.0.2",
    "vercel-analytics": "1.4.1"
  },
  "core": [
    { "module": "next", "ref": "next", "rationale": "Framework App Router + RSC + Server Actions" },
    { "module": "react", "ref": "react", "rationale": "UI lib compatible RSC" },
    { "module": "react-dom", "ref": "react" },
    { "module": "@types/react", "ref": "react-types" },
    { "module": "@types/react-dom", "ref": "react-dom-types" },
    { "module": "@types/node", "ref": "node-types" },
    { "module": "typescript", "ref": "typescript" },
    { "module": "tailwindcss", "ref": "tailwindcss" },
    { "module": "@tailwindcss/postcss", "ref": "tailwindcss" },
    { "module": "postcss", "ref": "postcss" },
    { "module": "zod", "ref": "zod", "rationale": "Validation schemas (server + client)" },
    { "module": "react-hook-form", "ref": "react-hook-form" },
    { "module": "@hookform/resolvers", "ref": "hookform-resolvers" },
    { "module": "next-auth", "ref": "next-auth", "rationale": "Auth (NextAuth v5 / Auth.js)" },
    { "module": "next-intl", "ref": "next-intl", "rationale": "i18n" },
    { "module": "pino", "ref": "pino" },
    { "module": "pino-pretty", "ref": "pino-pretty" },
    { "module": "eslint", "ref": "eslint" },
    { "module": "eslint-config-next", "ref": "eslint-next" }
  ],
  "onDemand": [
    { "module": "prisma", "ref": "prisma", "capability": "prisma", "triggers": ["DatabaseType.*\\b(SqlServer|PostgreSql|MySql|Sqlite)\\b", "orm", "db-first"] },
    { "module": "@prisma/client", "ref": "prisma-client", "capability": "prisma", "triggers": ["prisma", "orm"] },
    { "module": "@azure/msal-node", "ref": "msal-node", "capability": "auth-azure-ad", "triggers": ["auth-azure-ad", "msal"] },
    { "module": "jose", "ref": "jose", "capability": "jwt", "triggers": ["\\bjwt\\b", "auth-local"] },
    { "module": "undici", "ref": "undici", "capability": "http-client", "triggers": ["appel.*api.*externe", "http-client"] },
    { "module": "exceljs", "ref": "exceljs", "capability": "excel", "triggers": ["\\bexcel\\b", "\\.xlsx\\b", "export.*excel"] },
    { "module": "@react-pdf/renderer", "ref": "react-pdf", "capability": "pdf", "triggers": ["\\bpdf\\b", "export.*pdf"] },
    { "module": "nodemailer", "ref": "nodemailer", "capability": "smtp", "triggers": ["email", "smtp", "envoi.*mail"] },
    { "module": "date-fns", "ref": "date-fns", "capability": "date-utils", "triggers": ["dates.*format", "duree", "intervalle.*temps"] },
    { "module": "zustand", "ref": "zustand", "capability": "state-mgmt", "triggers": ["global.*state", "store", "zustand"] },
    { "module": "@vercel/analytics", "ref": "vercel-analytics", "capability": "analytics", "triggers": ["analytics", "telemetry.*ui"] }
  ]
}
