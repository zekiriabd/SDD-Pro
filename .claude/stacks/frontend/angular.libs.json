{
  "$schema": "../../templates/libs-catalog.schema.json",
  "stackId": "angular",
  "category": "frontend",
  "schemaVersion": 1,
  "buildSystem": "npm",
  "manifest": {
    "files": [
      "workspace/output/src/{AppName}/package.json",
      "workspace/output/src/{AppName}/angular.json",
      "workspace/output/src/{AppName}/tsconfig.json"
    ]
  },
  "versions": {
    "angular": "19.0.5",
    "angular-cdk": "19.0.4",
    "angular-material": "19.0.4",
    "ngrx": "19.0.0",
    "msal-angular": "3.1.0",
    "msal-browser": "3.27.0",
    "ngx-translate-core": "16.0.4",
    "ngx-translate-http-loader": "16.0.0",
    "rxjs": "7.8.1",
    "zone": "0.15.0",
    "tslib": "2.8.1",
    "typescript": "5.6.3",
    "tanstack-angular-query": "5.62.7",
    "ngx-logger": "5.0.12",
    "dayjs": "1.11.13",
    "uuid": "11.0.5",
    "clsx": "2.1.1",
    "eslint": "9.17.0",
    "angular-eslint": "19.0.2",
    "typescript-eslint": "8.18.1",
    "prettier": "3.4.2"
  },
  "core": [
    { "module": "@angular/core", "ref": "angular" },
    { "module": "@angular/common", "ref": "angular" },
    { "module": "@angular/router", "ref": "angular" },
    { "module": "@angular/forms", "ref": "angular" },
    { "module": "@angular/platform-browser", "ref": "angular" },
    { "module": "@angular/platform-browser-dynamic", "ref": "angular" },
    { "module": "@angular/compiler", "ref": "angular" },
    { "module": "@angular/animations", "ref": "angular" },
    { "module": "@angular/cdk", "ref": "angular-cdk" },
    { "module": "@angular/material", "ref": "angular-material" },
    { "module": "@ngrx/store", "ref": "ngrx" },
    { "module": "@ngrx/effects", "ref": "ngrx" },
    { "module": "@ngrx/entity", "ref": "ngrx" },
    { "module": "@ngrx/router-store", "ref": "ngrx" },
    { "module": "@tanstack/angular-query-experimental", "ref": "tanstack-angular-query" },
    { "module": "rxjs", "ref": "rxjs" },
    { "module": "zone.js", "ref": "zone" },
    { "module": "tslib", "ref": "tslib" },
    { "module": "typescript", "ref": "typescript" },
    { "module": "@ngx-translate/core", "ref": "ngx-translate-core" },
    { "module": "@ngx-translate/http-loader", "ref": "ngx-translate-http-loader" },
    { "module": "ngx-logger", "ref": "ngx-logger" },
    { "module": "@angular-eslint/builder", "ref": "angular-eslint" },
    { "module": "eslint", "ref": "eslint" },
    { "module": "typescript-eslint", "ref": "typescript-eslint" },
    { "module": "prettier", "ref": "prettier" }
  ],
  "onDemand": [
    { "module": "@azure/msal-angular", "ref": "msal-angular", "capability": "auth-azure-ad", "triggers": ["azure.ad", "msal", "tech-auth-azure"] },
    { "module": "@azure/msal-browser", "ref": "msal-browser", "capability": "auth-azure-ad", "triggers": ["azure.ad", "msal", "tech-auth-azure"] },
    { "module": "dayjs", "ref": "dayjs", "capability": "date-utils", "triggers": ["dates.*format", "duree", "intervalle.*temps"] },
    { "module": "uuid", "ref": "uuid", "capability": "uuid-gen", "triggers": ["\\buuid\\b", "guid.*genere", "id.*aleatoire"] },
    { "module": "clsx", "ref": "clsx", "capability": "css-classes", "triggers": ["clsx", "classes.*conditionnel"] }
  ],
  "plugins": [],
  "metadata": { "lastUpdated": "2026-05-07", "format": "compact (v2)" }
}
