{
  "$schema": "../../templates/libs-catalog.schema.json",
  "stackId": "react",
  "category": "frontend",
  "schemaVersion": 1,
  "buildSystem": "pnpm",
  "manifest": {
    "files": [
      "workspace/output/src/{AppName}/pnpm-workspace.yaml",
      "workspace/output/src/{AppName}/turbo.json",
      "workspace/output/src/{AppName}/package.json",
      "workspace/output/src/{AppName}/apps/web/package.json"
    ],
    "versionCatalogPath": "pnpm-workspace.yaml"
  },
  "versions": {
    "react": "19.0.0",
    "react-types": "19.0.2",
    "react-dom-types": "19.0.2",
    "vite": "6.0.5",
    "vite-plugin-react": "4.3.4",
    "typescript": "5.7.2",
    "tailwindcss": "4.0.0",
    "tailwind-merge": "2.5.5",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "0.468.0",
    "tanstack-query": "5.62.7",
    "react-router-dom": "7.15.0",
    "react-hook-form": "7.54.1",
    "zod": "3.24.1",
    "hookform-resolvers": "3.10.0",
    "i18next": "24.1.0",
    "react-i18next": "15.2.0",
    "i18next-browser-languagedetector": "8.0.2",
    "i18next-http-backend": "3.0.1",
    "turbo": "2.3.3",
    "eslint": "9.17.0",
    "typescript-eslint": "8.18.1",
    "msal-browser": "5.10.1",
    "msal-react": "5.4.1",
    "tanstack-react-table": "8.20.5",
    "tanstack-react-router": "1.166.0",
    "tanstack-router-plugin": "1.166.0",
    "vite-plugin-basic-ssl": "2.0.0",
    "papaparse": "5.4.1",
    "papaparse-types": "5.3.15"
  },
  "core": [
    { "module": "react", "ref": "react" },
    { "module": "react-dom", "ref": "react" },
    { "module": "@types/react", "ref": "react-types" },
    { "module": "@types/react-dom", "ref": "react-dom-types" },
    { "module": "vite", "ref": "vite" },
    { "module": "@vitejs/plugin-react", "ref": "vite-plugin-react" },
    { "module": "typescript", "ref": "typescript" },
    { "module": "tailwindcss", "ref": "tailwindcss" },
    { "module": "@tailwindcss/vite", "ref": "tailwindcss" },
    { "module": "tailwind-merge", "ref": "tailwind-merge" },
    { "module": "clsx", "ref": "clsx" },
    { "module": "class-variance-authority", "ref": "class-variance-authority" },
    { "module": "lucide-react", "ref": "lucide-react" },
    { "module": "@tanstack/react-query", "ref": "tanstack-query" },
    { "module": "@tanstack/react-query-devtools", "ref": "tanstack-query" },
    { "module": "react-router-dom", "ref": "react-router-dom" },
    { "module": "react-hook-form", "ref": "react-hook-form" },
    { "module": "zod", "ref": "zod" },
    { "module": "@hookform/resolvers", "ref": "hookform-resolvers" },
    { "module": "i18next", "ref": "i18next" },
    { "module": "react-i18next", "ref": "react-i18next" },
    { "module": "i18next-browser-languagedetector", "ref": "i18next-browser-languagedetector" },
    { "module": "turbo", "ref": "turbo" },
    { "module": "eslint", "ref": "eslint" },
    { "module": "typescript-eslint", "ref": "typescript-eslint" }
  ],
  "onDemand": [
    { "module": "i18next-http-backend", "ref": "i18next-http-backend", "capability": "i18n-http-loading", "triggers": ["traductions.*serveur", "i18n.*lazy", "load.*translations.*remote"] },
    { "module": "@azure/msal-browser", "ref": "msal-browser", "capability": "auth-azure-ad", "triggers": ["azure ad", "msal", "single sign-on", "sso", "oauth2.*spa", "@azure/msal"] },
    { "module": "@azure/msal-react", "ref": "msal-react", "capability": "auth-azure-ad", "triggers": ["azure ad", "msal", "single sign-on", "sso", "oauth2.*spa", "@azure/msal"] },
    { "module": "@tanstack/react-table", "ref": "tanstack-react-table", "capability": "data-grid", "triggers": ["datagrid", "data grid", "tanstack.*table", "react-table", "tableau.*colonnes", "grille.*filtre"] },
    { "module": "papaparse", "ref": "papaparse", "capability": "csv-client", "triggers": ["csv.*client", "export.*csv.*frontend", "papaparse", "blob.*csv", "csv.*download.*navigateur"] },
    { "module": "@types/papaparse", "ref": "papaparse-types", "capability": "csv-client", "triggers": ["csv.*client", "export.*csv.*frontend", "papaparse", "blob.*csv", "csv.*download.*navigateur"] },
    { "module": "@tanstack/react-router", "ref": "tanstack-react-router", "capability": "router-tanstack", "triggers": ["tanstack.*router", "@tanstack/react-router", "file-based.*routing", "routes/__root", "routeTree.gen"] },
    { "module": "@tanstack/router-plugin", "ref": "tanstack-router-plugin", "capability": "router-tanstack", "triggers": ["tanstack.*router", "@tanstack/react-router", "file-based.*routing", "routes/__root", "routeTree.gen"] },
    { "module": "@vitejs/plugin-basic-ssl", "ref": "vite-plugin-basic-ssl", "capability": "dev-https", "triggers": ["https.*dev", "basic-ssl", "https.*localhost", "azure ad.*spa", "msal.*redirect.*localhost", "vite.*https"] }
  ],
  "plugins": [],
  "metadata": { "lastUpdated": "2026-05-12", "format": "compact (v2)", "patchNotes": "bump msal-react 2.2.0->5.4.1 + msal-browser 3.27.0->5.10.1 (React 19 peer-dep), add tanstack-react-router 1.166 (replaces react-router-dom for new projects), add vite-plugin-basic-ssl 2.0.0 (dev HTTPS for Azure AD MSAL popup)" }
}
