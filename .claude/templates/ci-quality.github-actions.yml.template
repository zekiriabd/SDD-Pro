# SDD_Pro v7.2.0 — CI quality workflow template
# Generated by /arch-init when CiTemplatesGeneration: true (default).
# Compensates retired agents : accessibility-auditor + performance-auditor.
#
# v7.2.0 — ingest pipeline wired:
#   axe-core JSON     → ingest_axe.py       → console.db.qa_a11y
#   Lighthouse JSON   → ingest_lighthouse.py → console.db.qa_performance
#   Both then read by /sdd-review for the consolidated verdict.
#
# Substitution tokens at scaffold time :
#   {{AppName}}      = frontend project name
#   {{BackendName}}  = backend project name
#   {{NodeVersion}}  = Node LTS (default 22)
#   {{DotnetVersion}}= .NET LTS (default 10) — empty if no backend .NET
#   {{FeatNumber}}   = FEAT number this PR ships (derived by CI step
#                      from branch name `feat/<N>-Name` ; defaults to 0
#                      when not parseable — telemetry still recorded).
#
# Place at .github/workflows/quality.yml in the generated project.
# Requires Python 3.10+ + the SDD framework checked-in at .claude/.

name: Quality (a11y + perf + cve)

on:
  pull_request:
    branches: [main, develop]
  push:
    branches: [main]
  workflow_dispatch:

jobs:
  a11y-axe:
    name: Accessibility (axe-core)
    runs-on: ubuntu-latest
    if: hashFiles('{{AppName}}/package.json') != ''
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '{{NodeVersion}}'
          cache: 'npm'
          cache-dependency-path: '{{AppName}}/package-lock.json'
      - name: Install axe-core CLI (pinned for reproducibility)
        # P1-4 fix 2026-06-07 : version pinned to avoid supply-chain
        # variance and silent breaking-change adoption.
        run: npm install -g @axe-core/cli@4.10.0
      - name: Build {{AppName}}
        working-directory: {{AppName}}
        run: npm ci && npm run build
      - name: Serve + scan
        working-directory: {{AppName}}
        run: |
          npm run preview &
          npx wait-on http://localhost:4173 -t 60000
          # `--exit` makes axe return non-zero on violations; we disable that
          # because the gating decision is made by ingest_axe.py against the
          # configured A11yFailOn threshold (uniform with /sdd-review).
          axe http://localhost:4173 --tags wcag2aa,wcag22aa --save axe-report.json || true
      - uses: actions/setup-python@v5
        with:
          python-version: '3.12'
      - name: Derive FEAT number
        id: feat
        run: |
          BRANCH="${GITHUB_HEAD_REF:-${GITHUB_REF_NAME}}"
          N=$(echo "$BRANCH" | sed -nE 's#^(feat|feature)/([0-9]+)[-_].*#\2#p')
          echo "n=${N:-0}" >> "$GITHUB_OUTPUT"
      - name: Ingest axe-core → console.db
        run: |
          python .claude/python/sdd_scripts/ingest_axe.py \
            --report {{AppName}}/axe-report.json \
            --feat ${{ steps.feat.outputs.n }} \
            --threshold serious
      - uses: actions/upload-artifact@v4
        if: always()
        with:
          name: axe-report
          path: '{{AppName}}/axe-report.json'

  lighthouse:
    name: Performance (Lighthouse CI)
    runs-on: ubuntu-latest
    if: hashFiles('{{AppName}}/package.json') != ''
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '{{NodeVersion}}'
          cache: 'npm'
          cache-dependency-path: '{{AppName}}/package-lock.json'
      - name: Install Lighthouse CI (pinned for reproducibility)
        # P1-4 fix 2026-06-07 : version pinned (same reason as axe-core).
        run: npm install -g @lhci/cli@0.14.0
      - name: Build {{AppName}}
        working-directory: {{AppName}}
        run: npm ci && npm run build
      - name: Run Lighthouse
        working-directory: {{AppName}}
        run: |
          npm run preview &
          npx wait-on http://localhost:4173 -t 60000
          lhci collect --url=http://localhost:4173 --numberOfRuns=3
          # `lhci assert` would gate via lighthouse-recommended; we skip it
          # and let ingest_lighthouse.py apply SDD-canonical thresholds so
          # the verdict aligns with /sdd-review.
        env:
          LHCI_GITHUB_APP_TOKEN: ${{ secrets.LHCI_GITHUB_APP_TOKEN }}
      - uses: actions/setup-python@v5
        with:
          python-version: '3.12'
      - name: Derive FEAT number
        id: feat
        run: |
          BRANCH="${GITHUB_HEAD_REF:-${GITHUB_REF_NAME}}"
          N=$(echo "$BRANCH" | sed -nE 's#^(feat|feature)/([0-9]+)[-_].*#\2#p')
          echo "n=${N:-0}" >> "$GITHUB_OUTPUT"
      - name: Ingest Lighthouse → console.db
        run: |
          python .claude/python/sdd_scripts/ingest_lighthouse.py \
            --report {{AppName}}/.lighthouseci/ \
            --feat ${{ steps.feat.outputs.n }} \
            --threshold serious
      - uses: actions/upload-artifact@v4
        if: always()
        with:
          name: lighthouse-report
          path: '{{AppName}}/.lighthouseci/'

  cve-npm:
    name: CVE scan (npm audit)
    runs-on: ubuntu-latest
    if: hashFiles('{{AppName}}/package.json') != ''
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: '{{NodeVersion}}'
      - name: npm audit
        working-directory: {{AppName}}
        run: |
          npm ci
          npm audit --omit=dev --audit-level=moderate

  cve-dotnet:
    name: CVE scan (dotnet vulnerable)
    runs-on: ubuntu-latest
    if: hashFiles('{{BackendName}}/{{BackendName}}.csproj') != ''
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-dotnet@v4
        with:
          dotnet-version: '{{DotnetVersion}}'
      - name: dotnet restore + audit
        working-directory: {{BackendName}}
        run: |
          dotnet restore
          dotnet list package --vulnerable --include-transitive --format json > cve-report.json
          # Fail if any High/Critical
          jq -e '[.projects[].frameworks[].topLevelPackages[]?, .projects[].frameworks[].transitivePackages[]?] | map(select(.vulnerabilities[]?.severity | IN("Critical","High"))) | length == 0' cve-report.json
      - uses: actions/upload-artifact@v4
        if: always()
        with:
          name: dotnet-cve-report
          path: '{{BackendName}}/cve-report.json'
