## Project Config
# FrontendName/BackendName = project names ; AppNamespace/BackendNamespace
# auto-derived (= project name, cf. CLAUDE.md В§1 + ownership.md В§1.bis).
# For fullstack stacks : drop the "Front" suffix (e.g. {{AppName}}Front в†’ {{AppName}}).
AppName: {{AppName}}
FrontendName: {{AppName}}
FrontendLocalPort: {{FrontendPort}}
BackendName: {{BackendName}}
BackendLocalPort: {{BackendPort}}
LibStrategy: {{LibStrategy}}
PlanReviewDefault: true

# QA mode :
#   off | quality-only | tests-only | tests+coverage | full | manual
QAMode: tests+coverage
CoverageMin: 80
MaxParallel: 3

# Cost caps (USD, see config.base.yml for full doc) :
MaxCostPerRun: 50
BuildLoopMaxCostUsd: 15
BuildLoopMaxIter: 3

# FailOn severity thresholds : info | minor | moderate | serious | critical
CodeReviewFailOn: critical
SecurityFailOn: critical
SpecComplianceFailOn: serious
ArchReviewFailOn: serious

# US granularity (1-6 per FEAT recommended) :
UsGranularityTarget: 3

# OWASP scan : keep true for serious runs
SecurityScanEnabled: true

# Auditor modes : off | manual | full
CodeReviewMode: full
SecurityMode: full
SpecComplianceMode: full
ArchReviewMode: manual
A11yMode: "off"
PerfMode: "off"

